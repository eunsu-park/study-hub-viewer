# Study Viewer - Environment Variables
# Copy to .env and fill in values

# Auth mode: set to "true" for multi-user mode with login
# Default: false (single-user mode, no login required)
AUTH_ENABLED=false

# REQUIRED when AUTH_ENABLED=true in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Flask environment (development / production)
FLASK_ENV=development
FLASK_APP=app.py

# Content path (optional; defaults to parent directory)
# STUDY_HUB_PATH=/path/to/study_hub
