# Nginx reverse proxy configuration for Multi-User Study Viewer
# Copy to /etc/nginx/sites-available/ and symlink to sites-enabled/
# Adjust server_name and paths as needed.

upstream study_viewer {
    server 127.0.0.1:5051;
}

server {
    listen 80;
    server_name study.example.com;  # Change to your domain or IP

    # Redirect HTTP to HTTPS (uncomment if using SSL)
    # return 301 https://$host$request_uri;

    # Static files served directly by Nginx (bypass Gunicorn)
    location /static/ {
        alias /opt/projects/01_Personal/02_Study_Hub/multi_viewer/static/;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # Proxy to Gunicorn
    location / {
        proxy_pass http://study_viewer;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # Max upload size (for future file uploads)
    client_max_body_size 10M;
}

